# /system/etc/init/rvc_app.rc
#
# Camera streaming daemon.
# Watches vendor.rvc.camera.active and controls the Camera2 NDK +
# AMediaCodec H.264 -> RTP/UDP pipeline.
#
# Started with class main so it is ready before rvc_service writes
# the property for the first time.

service rvc_app /system/bin/rvc_app
    class main
    user system
    group camera inet
    ioprio rt 4
    writepid /dev/cpuset/system-background/tasks
    onrestart restart rvc_app
